// Frag Platform — схема базы данных (Фаза 1: каталог + коллекция)
// Документация модели данных — в TECH_PLAN.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Пользователь (зеркалит Supabase Auth по id) ---
model User {
  id        String   @id @default(uuid())
  handle    String   @unique
  email     String   @unique
  name          String?
  avatarUrl     String?
  bio           String?  // короткое описание профиля
  favoriteNotes String[] @default([]) // любимые ноты для подбора
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  collection CollectionItem[]
  wishlist   WishlistItem[]
  posts      Post[]
  postLikes  PostLike[]
  comments   Comment[]
  wears      WearEntry[]

  sentRequests     Friendship[] @relation("requester")
  receivedRequests Friendship[] @relation("addressee")

  battlesChallenged Battle[] @relation("battleChallenger")
  battlesReceived   Battle[] @relation("battleOpponent")
}

// --- Баттл: квиз-дуэль с другом на одинаковых вопросах ---
model Battle {
  id             String       @id @default(uuid())
  challenger     User         @relation("battleChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challengerId   String
  opponent       User         @relation("battleOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  opponentId     String
  questions      Json // массив вопросов (с правильными ответами)
  challengerScore Int? // счёт того, кто бросил вызов (ставится при создании)
  opponentScore  Int? // счёт оппонента (null, пока не сыграл)
  status         BattleStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  @@index([opponentId])
  @@index([challengerId])
}

enum BattleStatus {
  PENDING // оппонент ещё не сыграл
  DONE
}

// --- Новость мира парфюмерии (из RSS парфюм-блогов) ---
model NewsItem {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique
  source      String // напр. "Now Smell This"
  summary     String   @db.Text
  imageUrl    String?
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([publishedAt])
}

// --- Пост (впечатление/отзыв об аромате) — шаримая соц-единица ---
model Post {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  fragrance   Fragrance @relation(fields: [fragranceId], references: [id])
  fragranceId String
  rating      Int? // 1..10, опционально
  body        String    @db.Text
  imageUrl    String? // пользовательское фото (Supabase Storage)
  createdAt   DateTime  @default(now())

  likes    PostLike[]
  comments Comment[]

  @@index([userId])
  @@index([fragranceId])
  @@index([createdAt])
}

// --- Комментарий к посту ---
model Comment {
  id        String   @id @default(uuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
}

// --- Лайк поста ---
model PostLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

// --- Дружба (запрос → принятие) ---
model Friendship {
  id          String       @id @default(uuid())
  requester   User         @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User         @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@index([requesterId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

// --- Бренд / дом ---
model Brand {
  id      String  @id @default(uuid())
  name    String  @unique
  slug    String  @unique
  country String?

  fragrances Fragrance[]
}

// --- Аромат (каталог) ---
model Fragrance {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  brand         Brand          @relation(fields: [brandId], references: [id])
  brandId       String
  house         String? // парфюмер
  releaseYear   Int?
  concentration Concentration?
  retailPrice   Decimal?       @db.Decimal(10, 2) // ориентир. ритейл-цена (до ценового слоя)
  retailVolume  Int? // мл, к которым относится retailPrice
  priceEstimated Boolean       @default(false) // true = цена оценочная (эвристика), не реальная
  notesTop      String[] // верхние ноты
  notesHeart    String[] // ноты сердца
  notesBase     String[] // базовые ноты
  imageUrl      String?
  popularity    Int            @default(0) // число оценок из датасета (для «популярных» в квизе/каталоге)
  sourceUrl     String? // URL страницы-источника (Parfumo) для on-demand дозагрузки фото
  externalIds   Json? // ссылки на источники (parfumo/fragrantica и т.п.)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  collectionItems CollectionItem[]
  wishlistItems   WishlistItem[]
  posts           Post[]
  wears           WearEntry[]

  @@index([brandId])
  @@index([name])
}

// --- «Аромат дня» (SOTD): чем пользователь пахнет сегодня ---
model WearEntry {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  fragrance   Fragrance @relation(fields: [fragranceId], references: [id])
  fragranceId String
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// --- Позиция в коллекции пользователя ---
model CollectionItem {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  fragrance    Fragrance @relation(fields: [fragranceId], references: [id])
  fragranceId  String
  type         ItemType  @default(BOTTLE)
  quantity     Int       @default(1) // сколько флаконов этого аромата
  volumeMl     Int? // объём флакона
  remainingPct Int       @default(100) // остаток в %
  purchasePrice Decimal? @db.Decimal(10, 2)
  purchaseDate DateTime?
  batchCode    String?
  isPublic     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([fragranceId])
}

// --- Вишлист ---
model WishlistItem {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  fragrance   Fragrance @relation(fields: [fragranceId], references: [id])
  fragranceId String
  targetPrice Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  @@unique([userId, fragranceId])
  @@index([userId])
}

enum ItemType {
  BOTTLE // флакон
  DECANT // отливант
  SAMPLE // сэмпл
}

enum Concentration {
  PARFUM
  EDP // eau de parfum
  EDT // eau de toilette
  EDC // eau de cologne
  EXTRAIT
  OTHER
}
